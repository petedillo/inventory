# Database
POSTGRES_DB=inventory
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password
DB_HOST=localhost

# Server
PORT=3000
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your-secret-key-change-in-production
